.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8FAFC;
}

.product-strip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #EEF2F7;
}

.product-strip--active {
  background: #F8FAFC;
}

.product-cover {
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  background: #E5E7EB;
  flex-shrink: 0;
}

.product-info {
  min-width: 0;
  flex: 1;
}

.product-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6B7280;
}

.list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.msg {
  display: flex;
  margin-bottom: 24rpx;
}

.msg.me {
  justify-content: flex-end;
}

.bubble {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.msg.other .bubble {
  background: #fff;
  color: #111827;
  border-top-left-radius: 6rpx;
}

.msg.me .bubble {
  background: #3B82F6;
  color: #fff;
  border-top-right-radius: 6rpx;
}

.empty-hint {
  text-align: center;
  color: #9CA3AF;
  padding: 60rpx 0;
  font-size: 26rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #F1F5F9;
}

.input {
  flex: 1;
  background: #F1F5F9;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 72rpx;
  font-size: 28rpx;
}

.send {
  margin: 0;
  min-width: 128rpx;
  color: #fff;
  background: #3B82F6;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
}

.send::after {
  border: 0;
}
