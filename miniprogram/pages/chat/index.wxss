.page { display: flex; flex-direction: column; height: 100vh; background: #F8FAFC; }
.list { flex: 1; padding: 24rpx; }
.msg { display: flex; margin-bottom: 24rpx; }
.msg.me { justify-content: flex-end; }
.bubble {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}
.msg.other .bubble { background: #fff; color: #111827; border-top-left-radius: 6rpx; }
.msg.me .bubble { background: #3B82F6; color: #fff; border-top-right-radius: 6rpx; }
.empty-hint { text-align: center; color: #9CA3AF; padding: 60rpx 0; font-size: 26rpx; }

.input-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #F1F5F9;
}
.input {
  flex: 1; background: #F1F5F9;
  border-radius: 999rpx; padding: 0 24rpx; height: 72rpx; font-size: 28rpx;
}
.send {
  color: #fff; background: #3B82F6;
  padding: 0 32rpx; height: 72rpx; line-height: 72rpx;
  border-radius: 999rpx; font-size: 28rpx;
}
