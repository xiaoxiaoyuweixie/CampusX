.page { padding: 24rpx 24rpx 200rpx; }
.section { padding: 24rpx; margin-bottom: 20rpx; }
.label { font-size: 26rpx; color: #6B7280; margin-bottom: 16rpx; }
.img-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item, .img-add {
  width: 180rpx; height: 180rpx;
  border-radius: 12rpx; overflow: hidden;
  position: relative;
}
.img-item image { width: 100%; height: 100%; }
.img-del {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 36rpx; height: 36rpx; line-height: 32rpx; text-align: center;
  background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%;
  font-size: 28rpx;
}
.img-add {
  background: #F1F5F9;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #9CA3AF;
}
.plus { font-size: 56rpx; line-height: 1; }
.add-text { font-size: 22rpx; margin-top: 6rpx; }

.row { display: flex; align-items: center; padding: 18rpx 0; }
.row-label { width: 120rpx; font-size: 28rpx; color: #111827; }
.row-input { flex: 1; font-size: 28rpx; color: #111827; }
.picker { color: #111827; }
.divider { height: 1rpx; background: #F1F5F9; }

.textarea { width: 100%; min-height: 220rpx; font-size: 28rpx; }

.footer {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 20rpx 32rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #F1F5F9;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}
