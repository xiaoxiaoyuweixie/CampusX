.page { padding: 24rpx 24rpx 40rpx; }
.header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.school { font-size: 26rpx; color: #111827; font-weight: 500; }
.banner {
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  color: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.25);
}
.banner-title { font-size: 36rpx; font-weight: 600; }
.banner-sub { font-size: 24rpx; margin-top: 10rpx; opacity: 0.92; }

.cat-grid {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  margin-bottom: 28rpx;
}
.cat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.cat-icon { font-size: 48rpx; }
.cat-name { font-size: 26rpx; color: #374151; }

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin: 8rpx 0 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.grid-col { width: 100%; }
