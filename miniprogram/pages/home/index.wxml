<view class="page">
  <view class="header">
    <view class="school">📍 {{school}}</view>
    <search-bar value="{{keyword}}" bind:input="onSearchInput" bind:confirm="onSearchConfirm" />
  </view>

  <view class="banner">
    <view class="banner-title">校园资源 · 同学之间</view>
    <view class="banner-sub">闲置 / 教材 / 资料 / 技能，一键发布</view>
  </view>

  <view class="cat-grid">
    <view class="cat-item" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="onCategoryTap">
      <view class="cat-icon">{{item.icon}}</view>
      <view class="cat-name">{{item.name}}</view>
    </view>
  </view>

  <view class="section-title">推荐资源</view>
  <view class="grid">
    <view class="grid-col" wx:for="{{products}}" wx:key="id">
      <product-card product="{{item}}" bind:tap="onProductTap" />
    </view>
  </view>
</view>
