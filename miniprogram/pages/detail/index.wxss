.swiper { width: 100%; height: 600rpx; background: #F1F5F9; }
.swiper-img { width: 100%; height: 100%; }
.indicator {
  position: absolute; top: 560rpx; right: 24rpx;
  background: rgba(0,0,0,0.4); color: #fff;
  padding: 4rpx 16rpx; border-radius: 999rpx; font-size: 22rpx;
}
.block { margin: 20rpx 24rpx; padding: 24rpx; }
.price { color: #EF4444; font-size: 44rpx; font-weight: 700; }
.title { font-size: 32rpx; color: #111827; margin: 12rpx 0; font-weight: 500; }
.meta { display: flex; align-items: center; gap: 16rpx; margin-top: 10rpx; }
.sub { color: #6B7280; font-size: 24rpx; }
.section-label { font-size: 26rpx; color: #6B7280; margin-bottom: 12rpx; }
.desc { font-size: 28rpx; color: #111827; line-height: 1.7; white-space: pre-wrap; }
.info-row { font-size: 28rpx; color: #111827; }

.seller { display: flex; align-items: center; gap: 20rpx; }
.avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  color: #fff; font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
}
.seller-name { font-size: 30rpx; color: #111827; font-weight: 500; }

.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-top: 1rpx solid #F1F5F9;
  padding: 16rpx 24rpx;
  display: flex; align-items: center; gap: 20rpx;
}
.fav {
  display: flex; flex-direction: column; align-items: center;
  padding: 0 16rpx; color: #6B7280;
}
.fav-icon { font-size: 40rpx; color: #F59E0B; }
.fav-text { font-size: 22rpx; }
.contact-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.detail-empty {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6B7280;
  gap: 16rpx;
}
.empty-title { color: #111827; font-size: 32rpx; font-weight: 600; }
.empty-desc { font-size: 26rpx; }
