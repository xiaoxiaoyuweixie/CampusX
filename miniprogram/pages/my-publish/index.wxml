<view class="page">
  <view class="stat-card">
    <view class="stat-header">
      <view class="stat-title">我发布的资源</view>
      <view class="stat-sub">管理你在 CampusX 发布的全部内容</view>
    </view>
    <view class="stat-row">
      <view class="stat-item">
        <view class="stat-num">{{onsaleCount}}</view>
        <view class="stat-label">在售</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-num stat-num--muted">{{offlineCount}}</view>
        <view class="stat-label">已下架</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-num stat-num--sold">{{soldCount}}</view>
        <view class="stat-label">已售出</view>
      </view>
    </view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'tab-item--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      {{item.name}}
    </view>
  </view>

  <view wx:if="{{list.length > 0}}" class="list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      bindtap="onCardTap"
    >
      <image class="cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="info">
        <view class="title-row">
          <view class="title">{{item.title}}</view>
          <view class="status-tag {{item.status === 'on_sale' ? 'status-tag--on' : item.status === 'sold' ? 'status-tag--sold' : 'status-tag--off'}}">
            {{item.status === 'on_sale' ? '在售' : item.status === 'sold' ? '已售出' : '已下架'}}
          </view>
        </view>
        <view class="price">￥<text class="price-num">{{item.price}}</text></view>
        <view class="meta">发布时间：{{item.publishedAt}}</view>
        <view class="meta-row">
          <text class="meta-item">浏览 {{item.views}}</text>
          <text class="meta-dot">·</text>
          <text class="meta-item">收藏 {{item.favorites}}</text>
        </view>
      </view>
      <view class="actions">
        <view
          wx:if="{{item.status !== 'sold'}}"
          class="action-btn {{item.status === 'on_sale' ? 'action-btn--danger' : 'action-btn--success'}}"
          catchtap="onToggleStatus"
          data-id="{{item.id}}"
        >
          {{item.status === 'on_sale' ? '下架' : '恢复'}}
        </view>
        <view
          wx:if="{{item.status === 'on_sale'}}"
          class="action-btn action-btn--success"
          catchtap="onMarkSold"
          data-id="{{item.id}}"
        >
          标记已售出
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <view class="empty-art">
      <view class="empty-icon">＋</view>
    </view>
    <view class="empty-title">暂无发布内容</view>
    <view class="empty-sub">快去发布你的第一条校园资源吧</view>
    <view class="empty-btn" bindtap="onGoPublish">立即发布</view>
  </view>
</view>
