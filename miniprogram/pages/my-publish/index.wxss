.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding: 24rpx 24rpx 64rpx;
  box-sizing: border-box;
}

/* 统计卡片 */
.stat-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
}
.stat-header { margin-bottom: 28rpx; }
.stat-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}
.stat-sub {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 6rpx;
}
.stat-row {
  display: flex;
  align-items: center;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #0F172A;
  line-height: 1;
}
.stat-num--primary { color: #3B82F6; }
.stat-num--muted { color: #94A3B8; }
.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748B;
}
.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: #E2E8F0;
}

/* Tabs */
.tabs {
  display: flex;
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
}
.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #6B7280;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}
.tab-item--active {
  background: #3B82F6;
  color: #ffffff;
  font-weight: 600;
}

/* 列表 */
.list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
}
.cover {
  width: 192rpx;
  height: 192rpx;
  border-radius: 12rpx;
  background: #F1F5F9;
  flex-shrink: 0;
}
.card {
  flex-direction: row;
  align-items: flex-start;
  flex-wrap: wrap;
}
.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}
.title {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.status-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.6;
}
.status-tag--on {
  background: #E8F1FF;
  color: #3B82F6;
}
.status-tag--off {
  background: #F3F4F6;
  color: #6B7280;
}
.price {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #EF4444;
}
.price-num {
  font-size: 34rpx;
  font-weight: 700;
  margin-left: 2rpx;
}
.meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94A3B8;
}
.meta-row {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94A3B8;
}
.meta-dot { margin: 0 8rpx; }

/* 操作按钮 */
.actions {
  width: 100%;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F1F5F9;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.action-btn {
  font-size: 26rpx;
  color: #475569;
  background: #F1F5F9;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}
.action-btn--danger {
  color: #EF4444;
  background: #FEF2F2;
}
.action-btn--success {
  color: #16A34A;
  background: #ECFDF5;
}

/* 空状态 */
.empty {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-art {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #EFF6FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.empty-icon {
  font-size: 100rpx;
  color: #3B82F6;
  line-height: 1;
  font-weight: 300;
}
.empty-title {
  font-size: 32rpx;
  color: #0F172A;
  font-weight: 600;
}
.empty-sub {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}
.empty-btn {
  margin-top: 40rpx;
  background: #3B82F6;
  color: #ffffff;
  font-size: 28rpx;
  padding: 20rpx 64rpx;
  border-radius: 999rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.3);
}
