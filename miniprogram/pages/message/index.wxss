.page {
  padding: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #6B7280;
  margin: 8rpx 0 12rpx 8rpx;
}

.list {
  padding: 8rpx 0;
  margin-bottom: 24rpx;
}

.item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.item + .item {
  border-top: 1rpx solid #F1F5F9;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-image {
  background: #E5E7EB;
}

.avatar.sys {
  background: linear-gradient(135deg, #F59E0B, #FCD34D);
}

.body {
  flex: 1;
  min-width: 0;
}

.row1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.name {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  font-size: 22rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.product-line {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #3B82F6;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6rpx;
  gap: 16rpx;
}

.last {
  font-size: 26rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.badge {
  background: #EF4444;
  color: #fff;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
  flex-shrink: 0;
}

.loading {
  text-align: center;
  color: #9CA3AF;
  padding: 48rpx 0;
  font-size: 26rpx;
}
