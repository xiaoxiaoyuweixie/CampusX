<view class="page">
  <view class="header">
    <image wx:if="{{user.avatar}}" class="avatar avatar-image" src="{{user.avatar}}" mode="aspectFill"></image>
    <view wx:else class="avatar">{{user.nickname[0] || 'X'}}</view>
    <view class="info">
      <view class="nickname">{{user.nickname}}</view>
      <view class="school">
        🎓 {{user.school}}
        <text class="verify {{user.verified ? 'ok' : ''}}">{{user.verified ? '已认证' : '未认证'}}</text>
      </view>
    </view>
    <view wx:if="{{!user.logged}}" class="login-btn" bindtap="onLogin">登录</view>
  </view>

  <view class="stats card">
    <view class="stat" data-action="published" bindtap="onMenuTap">
      <view class="num">{{publishedCount}}</view>
      <view class="lbl">我的发布</view>
    </view>
    <view class="stat" data-action="favorites" bindtap="onMenuTap">
      <view class="num">{{favoriteCount}}</view>
      <view class="lbl">我的收藏</view>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" data-action="published" bindtap="onMenuTap">
      <text class="m-icon">📦</text>
      <text class="m-text">我的发布</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" data-action="favorites" bindtap="onMenuTap">
      <text class="m-icon">⭐</text>
      <text class="m-text">我的收藏</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" data-action="settings" bindtap="onMenuTap">
      <text class="m-icon">⚙️</text>
      <text class="m-text">设置</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" data-action="about" bindtap="onMenuTap">
      <text class="m-icon">ℹ️</text>
      <text class="m-text">关于我们</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="version">CampusX · 校易通 MVP v0.1</view>
</view>
