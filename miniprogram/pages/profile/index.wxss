.page { padding: 24rpx; }
.header {
  display: flex; align-items: center; gap: 24rpx;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  border-radius: 20rpx; padding: 40rpx 32rpx; color: #fff;
  margin-bottom: 24rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2);
  font-size: 48rpx; display: flex; align-items: center; justify-content: center;
}
.info { flex: 1; }
.nickname { font-size: 36rpx; font-weight: 600; }
.school { font-size: 24rpx; margin-top: 8rpx; opacity: 0.95; }
.verify {
  margin-left: 12rpx; padding: 2rpx 14rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.25); font-size: 20rpx;
}
.verify.ok { background: #10B981; }
.login-btn {
  background: #fff; color: #3B82F6;
  padding: 12rpx 28rpx; border-radius: 999rpx;
  font-size: 26rpx; font-weight: 600;
}

.stats { display: flex; padding: 32rpx 0; margin-bottom: 24rpx; }
.stat { flex: 1; text-align: center; }
.stat + .stat { border-left: 1rpx solid #F1F5F9; }
.num { font-size: 40rpx; font-weight: 600; color: #111827; }
.lbl { font-size: 24rpx; color: #6B7280; margin-top: 6rpx; }

.menu { overflow: hidden; }
.menu-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 24rpx;
  font-size: 28rpx; color: #111827;
}
.menu-item + .menu-item { border-top: 1rpx solid #F1F5F9; }
.m-icon { font-size: 32rpx; }
.m-text { flex: 1; }
.arrow { color: #9CA3AF; font-size: 32rpx; }

.version {
  text-align: center; color: #9CA3AF; font-size: 22rpx; margin-top: 40rpx;
}
