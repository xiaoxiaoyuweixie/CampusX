.page { padding: 24rpx; }
.header {
  display: flex; align-items: flex-start; gap: 24rpx;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  border-radius: 20rpx; padding: 40rpx 32rpx; color: #fff;
  margin-bottom: 24rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  flex: 0 0 120rpx;
  background: rgba(255,255,255,0.2);
  font-size: 48rpx; display: flex; align-items: center; justify-content: center;
}
.avatar-image { background: rgba(255,255,255,0.2); }
.info { flex: 1; min-width: 0; padding-top: 16rpx; }
.identity-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}
.nickname {
  flex: 0 1 auto;
  max-width: 180rpx;
  font-size: 36rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.school {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  gap: 10rpx;
  font-size: 24rpx;
  opacity: 0.95;
  white-space: nowrap;
  overflow: hidden;
}
.bio {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.5;
  font-style: italic;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: rgba(255,255,255,0.92);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.18);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.verify {
  flex: 0 0 auto;
  padding: 2rpx 14rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.25); font-size: 20rpx;
}
.verify.ok { background: #10B981; }
.login-btn {
  background: #fff; color: #3B82F6;
  padding: 12rpx 28rpx; border-radius: 999rpx;
  font-size: 26rpx; font-weight: 600;
}

.stats { display: flex; padding: 32rpx 0; margin-bottom: 24rpx; }
.stat { flex: 1; text-align: center; }
.stat + .stat { border-left: 1rpx solid #F1F5F9; }
.num { font-size: 40rpx; font-weight: 600; color: #111827; }
.lbl { font-size: 24rpx; color: #6B7280; margin-top: 6rpx; }

.menu { overflow: hidden; }
.menu-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 24rpx;
  font-size: 28rpx; color: #111827;
}
.menu-item + .menu-item { border-top: 1rpx solid #F1F5F9; }
.m-icon { font-size: 32rpx; }
.m-text { flex: 1; }
.arrow { color: #9CA3AF; font-size: 32rpx; }

.version {
  text-align: center; color: #9CA3AF; font-size: 22rpx; margin-top: 40rpx;
}
