<view class="page">
  <!-- 统计卡片 -->
  <view class="stat-card">
    <view class="stat-left">
      <view class="stat-title">我的收藏</view>
      <view class="stat-sub">已收藏资源</view>
    </view>
    <view class="stat-right">
      <text class="stat-num">{{total}}</text>
      <text class="stat-unit">条</text>
    </view>
  </view>

  <!-- 分类 Tab -->
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'tab-item--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 列表 -->
  <view wx:if="{{list.length > 0}}" class="list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      bindtap="onCardTap"
    >
      <image class="cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="info">
        <view class="title">{{item.title}}</view>
        <view class="price">¥<text class="price-num">{{item.price}}</text></view>
        <view class="meta">
          <text class="meta-item">{{item.campus}}</text>
          <text class="meta-dot">·</text>
          <text class="meta-item">浏览 {{item.views}}</text>
        </view>
        <view class="seller">发布者：{{item.sellerName}}</view>
      </view>
      <view
        class="fav-tag"
        catchtap="onUnfavorite"
        data-id="{{item.id}}"
      >
        <text class="fav-heart">♥</text>
        <text class="fav-text">已收藏</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <view class="empty-art">
      <view class="empty-heart">♡</view>
    </view>
    <view class="empty-title">暂无收藏内容</view>
    <view class="empty-sub">快去首页发现感兴趣的资源吧</view>
    <view class="empty-btn" bindtap="onGoHome">去逛逛</view>
  </view>
</view>
