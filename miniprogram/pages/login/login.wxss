.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}
.login-page__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.login-page__overlay {
  min-height: 100vh;
  padding: 180rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}
.login-page__avatar-wrap {
  width: 302rpx;
  height: 302rpx;
  border-radius: 314rpx;
  margin-bottom: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.login-page__avatar {
  width: 302rpx;
  height: 302rpx;
  border-radius: 314rpx;
}
.login-page__panel {
  width: 100%;
}
.login-page__input-box {
  width: 670rpx;
  height: 116rpx;
  background: rgba(245, 245, 245, 0.5);
  border-radius: 170rpx;
  transform: rotate(-0.01deg);
  padding: 0 44rpx;
  display: flex;
  align-items: center;
}
.login-page__input-box--password {
  margin-top: 24rpx;
}
.login-page__input {
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: #1f2937;
}
.login-page__placeholder {
  color: rgba(255, 255, 255, 0.82);
}
.login-page__agreement {
  width: 100%;
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding-left: 165rpx;
}
.login-page__check {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}
.login-page__agreement-text {
  font-family: Inter, sans-serif;
  font-style: normal;
  font-weight: 500;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #f5f5f5;
}
.login-page__agreement-link {
  color: #ff343e;
}
.login-page__submit {
  margin-top: 25rpx;
  width: 102rpx;
  min-width: 102rpx;
  max-width: 102rpx;
  height: 102rpx;
  min-height: 102rpx;
  border-radius: 50%;
  background: #2f7ff5;
  border: 0;
  padding: 0;
  display: inline-flex;
  flex: none;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.login-page__submit::after {
  border: none;
}
.login-page__submit-icon {
  width: auto;
  height: auto;
  color: #fef7ff;
  font-size: 85rpx;
  line-height: 1;
  text-align: center;
  display: block;
  transform: translate(4rpx, -12rpx);
}