    <view class="divider"></view>
    <view class="row" data-label="账号安全" bindtap="onAccountTap">
      <view class="row-label">
        <view class="icon-wrap"><view class="i-shield"></view></view>
        <text>账号安全</text>
      </view>
      <view class="row-value">
        <text class="row-text safe">{{account.security}}</text>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

