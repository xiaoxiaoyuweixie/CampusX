<!-- 设置页面 -->
<view class="settings-page">

  <!-- 个人资料 -->
  <view class="section-title">个人资料</view>
  <view class="card group">
    <view class="row row-avatar">
      <view class="row-label">头像</view>
      <view class="row-value avatar-value">
        <image wx:if="{{profile.avatar}}" class="avatar avatar-image" src="{{profile.avatar}}" mode="aspectFill"></image>
        <view wx:else class="avatar">{{profile.nickname[0] || 'X'}}</view>
      </view>
      <view class="arrow avatar-arrow">›</view>
      <button class="avatar-trigger" open-type="chooseAvatar" bindchooseavatar="onChooseWechatAvatar"></button>
    </view>
    <view class="divider"></view>

    <view class="row" data-field="nickname" data-label="昵称" bindtap="onEditField">
      <view class="row-label">昵称</view>
      <view class="row-value">
        <text class="row-text">{{profile.nickname}}</text>
        <view class="arrow">›</view>
      </view>
    </view>
    <view class="divider"></view>

    <view class="row" data-field="gender" data-label="性别" bindtap="onEditField">
      <view class="row-label">性别</view>
      <view class="row-value">
        <text class="row-text">{{profile.gender}}</text>
        <view class="arrow">›</view>
      </view>
    </view>
    <view class="divider"></view>

    <view class="row" data-field="bio" data-label="个人简介" bindtap="onEditField">
      <view class="row-label">个人简介</view>
      <view class="row-value">
        <text class="row-text ellipsis">{{profile.bio}}</text>
        <view class="arrow">›</view>
      </view>
    </view>
    <view class="divider"></view>

    <!--
    <view class="row" data-field="school" data-label="所在学校" bindtap="onEditField">
      <view class="row-label">所在学校</view>
      <view class="row-value">
        <text class="row-text">{{profile.school}}</text>
        <view class="arrow">›</view>
      </view>
    </view>
    -->
  </view>

  <!-- 账号与安全
