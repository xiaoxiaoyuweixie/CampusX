      <view class="row-label">
        <view class="icon-wrap"><view class="i-phone"></view></view>
        <text>手机号</text>
      </view>
      <view class="row-value">
        <text class="row-text">{{account.phone}}</text>
        <view class="arrow">›</view>
      </view>
