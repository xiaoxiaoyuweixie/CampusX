.wrap { display: flex; height: 100vh; background: #F8FAFC; }
.side {
  width: 180rpx;
  background: #fff;
  border-right: 1rpx solid #E5E7EB;
  padding-top: 12rpx;
}
.side-item {
  padding: 28rpx 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6B7280;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border-left: 4rpx solid transparent;
}
.side-item.active {
  color: #3B82F6;
  background: #F8FAFC;
  border-left-color: #3B82F6;
  font-weight: 600;
}
.emoji { font-size: 32rpx; }
.main { flex: 1; padding: 20rpx; overflow: hidden; }
.sort { display: flex; gap: 24rpx; padding: 8rpx 4rpx 20rpx; }
.sort-item {
  font-size: 26rpx;
  color: #6B7280;
  padding: 8rpx 0;
}
.sort-item.active { color: #3B82F6; font-weight: 600; }
.list { display: flex; flex-direction: column; gap: 16rpx; }
