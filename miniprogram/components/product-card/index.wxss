.product-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}
.card-hover { opacity: 0.85; }
.cover {
  width: 100%;
  height: 320rpx;
  background: #F1F5F9;
  display: block;
}
.info { padding: 16rpx 20rpx 20rpx; }
.title {
  font-size: 28rpx;
  color: #111827;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 80rpx;
}
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.text-price { color: #EF4444; font-weight: 600; font-size: 32rpx; }
.campus { font-size: 22rpx; color: #6B7280; }
.meta {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6B7280;
}
